# ── Application Environment ──
APP_ENV=development              # Окружение: development | test | production
DEBUG=false                      # Режим отладки (true/false)
LOG_LEVEL=INFO                   # Уровень логирования: DEBUG | INFO | WARNING | ERROR | CRITICAL

# ── HTTP Server ──
HTTP_HOST=0.0.0.0                # Хост для HTTP-сервера
HTTP_PORT=8000                   # Порт HTTP-сервера

# ── gRPC Server ──
GRPC_HOST=0.0.0.0                # Хост для gRPC-сервера
GRPC_PORT=50051                  # Порт gRPC-сервера

# ── Database (PostgreSQL) ──
POSTGRES_USER=player             # Имя пользователя БД
POSTGRES_PASSWORD=change-me      # Пароль пользователя БД
POSTGRES_HOST=localhost          # Хост PostgreSQL
POSTGRES_PORT=5432               # Порт PostgreSQL (по умолчанию 5432)
POSTGRES_DB=player_db            # Имя базы данных
POSTGRES_SQL_ECHO=false          # Логирование SQL-запросов через SQLAlchemy (true для отладки)